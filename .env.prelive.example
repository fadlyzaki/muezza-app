# Local prelive development
# Copy these values into .env.local when you need to switch back to prelive.

VITE_APP_URL=http://localhost:5173
VITE_QF_ENV=prelive
VITE_QURAN_CLIENT_ID=3ad66fcb-cfd6-45b4-b128-21218ac0f79a

# Server-side only. Do not expose this with a VITE_ prefix.
QF_CLIENT_SECRET=your-prelive-client-secret

# Optional explicit overrides. Leave unset unless Quran Foundation gives you custom hosts.
# VITE_QURAN_AUTH_BASE=https://prelive-oauth2.quran.foundation
# VITE_QURAN_USER_API_BASE=https://apis-prelive.quran.foundation
