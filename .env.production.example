# Vercel production environment variables
# Add these in the Vercel dashboard, not in a committed .env file.

VITE_APP_URL=https://your-production-domain.com
VITE_QF_ENV=production
VITE_QURAN_CLIENT_ID=your-production-client-id

# Server-side only. Do not expose this with a VITE_ prefix.
QF_CLIENT_SECRET=your-production-client-secret

# Optional explicit overrides. Leave unset unless Quran Foundation gives you custom hosts.
# VITE_QURAN_AUTH_BASE=https://oauth2.quran.foundation
# VITE_QURAN_USER_API_BASE=https://apis.quran.foundation
